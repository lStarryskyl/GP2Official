actor "Software Engineer" as SE <<Primary>> #LightGreen
actor "Project Manager" as PM <<Primary>> #LightYellow
actor "System Admin" as ADMIN <<Secondary>> #LightCoral
actor "AI Agent System" as AI <<System>> #Plum

rectangle "The Architect AI System" {
  
