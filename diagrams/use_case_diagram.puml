@startuml The_Architect_AI_Use_Case_Diagram

!define RECTANGLE_COLOR #E8F4F8
!define ACTOR_COLOR #FFE5B4

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

' Define Actors
