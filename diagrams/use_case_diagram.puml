  }
  
  package "AI Processing" {
    usecase "UC-11: Trigger AI Processing" as UC11
    usecase "UC-12: Extract Requirements" as UC12
    usecase "UC-13: Generate SRS Document" as UC13
    usecase "UC-14: Generate UML Diagrams" as UC14
